# ==========================================
# VARIABLES DE ENTORNO PARA AGENTES/CI/CD
# ==========================================

# --- Supabase ---
# Token de acceso personal de Supabase (Generado en el dashboard: Access Tokens)
SUPABASE_ACCESS_TOKEN=tu_supabase_access_token
# Contraseña de la base de datos de tu proyecto Supabase
SUPABASE_DB_PASSWORD=tu_supabase_db_password
# Reference ID de tu proyecto Supabase (Se encuentra en la URL del panel o settings)
SUPABASE_PROJECT_REF_ID=tu_project_ref_id

# --- GitHub ---
# Personal Access Token (PAT) de GitHub con permisos de repo (creado en Developer Settings)
GH_TOKEN=tu_github_personal_access_token

# --- Vercel ---
# Token de acceso personal de Vercel (Generado en el dashboard de cuenta: Tokens)
VERCEL_TOKEN=tu_vercel_access_token
# ID de tu Organización/Usuario en Vercel (Opcional, pero ayuda a evitar prompts interactivos)
VERCEL_ORG_ID=tu_vercel_org_id
# ID del proyecto en Vercel (Generado al hacer el primer vercel link)
VERCEL_PROJECT_ID=tu_vercel_project_id

# ==========================================
# VARIABLES DE ENTORNO DEL FRONTEND (APP)
# (Estas son las que se agregan a Vercel para que la web funcione)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://tu-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key
